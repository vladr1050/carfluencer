# Nginx — Laravel API + Filament + React SPA (media owner / advertiser).
# Продакшен-домен: www.carplace.lv (и carplace.lv). TLS: certbot --nginx -d www.carplace.lv -d carplace.lv
# Сборка SPA: cd frontend && npm ci && npm run build
#   (VITE_API_URL не нужен, если /api на том же origin — см. docs/DEPLOY/16_carplace_lv.md)
# Артефакты: /var/www/carfluencer/frontend/dist

server {
    listen 80;
    listen [::]:80;
    server_name www.carplace.lv carplace.lv;
    root /var/www/carfluencer/backend/public;

    client_max_body_size 32m;

    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";

    index index.php;
    charset utf-8;

    location ^~ /assets/ {
        alias /var/www/carfluencer/frontend/dist/assets/;
        access_log off;
        expires 7d;
        add_header Cache-Control "public";
    }

    location = / {
        root /var/www/carfluencer/frontend/dist;
        try_files /index.html =404;
    }

    # SPA fallback через named location (иначе /index.html уйдёт в Laravel location /)
    location ^~ /media-owner {
        root /var/www/carfluencer/frontend/dist;
        try_files $uri $uri/ @carfluencer_spa;
    }

    location ^~ /advertiser {
        root /var/www/carfluencer/frontend/dist;
        try_files $uri $uri/ @carfluencer_spa;
    }

    location ^~ /login {
        root /var/www/carfluencer/frontend/dist;
        try_files $uri $uri/ @carfluencer_spa;
    }

    location ^~ /register {
        root /var/www/carfluencer/frontend/dist;
        try_files $uri $uri/ @carfluencer_spa;
    }

    location ^~ /welcome {
        root /var/www/carfluencer/frontend/dist;
        try_files $uri $uri/ @carfluencer_spa;
    }

    location @carfluencer_spa {
        root /var/www/carfluencer/frontend/dist;
        try_files /index.html =404;
    }

    # Браузеры запрашивают /favicon.ico — отдаём SVG (иначе 204 → Safari может показать чужой кэш-иконки).
    location = /favicon.ico {
        access_log off;
        log_not_found off;
        rewrite ^ /favicon.svg break;
    }

    location = /robots.txt {
        access_log off;
        log_not_found off;
    }

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_pass unix:/run/php/php8.4-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_hide_header X-Powered-By;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
