#!/usr/bin/env bash
# ПЕРВЫЙ ДЕПЛОЙ НА VPS — скопируйте на сервер, выставьте chmod +x, отредактируйте переменные и запустите.
set -euo pipefail

APP_DIR="/var/www/carfluencer/backend"
APP_USER="evoapp"

echo "== Composer (no dev) =="
sudo -u "$APP_USER" -H bash -c "cd '$APP_DIR' && composer install --no-dev --optimize-autoloader"

echo "== Laravel =="
sudo -u "$APP_USER" -H bash -c "cd '$APP_DIR' && php artisan migrate --force"
sudo -u "$APP_USER" -H bash -c "cd '$APP_DIR' && php artisan storage:link || true"
sudo -u "$APP_USER" -H bash -c "cd '$APP_DIR' && php artisan config:cache"
sudo -u "$APP_USER" -H bash -c "cd '$APP_DIR' && php artisan route:cache"
sudo -u "$APP_USER" -H bash -c "cd '$APP_DIR' && php artisan view:cache"
sudo -u "$APP_USER" -H bash -c "cd '$APP_DIR' && php artisan filament:optimize || true"

echo "== Permissions =="
sudo chown -R "$APP_USER":www-data "$APP_DIR/storage" "$APP_DIR/bootstrap/cache"
sudo chmod -R ug+rwx "$APP_DIR/storage" "$APP_DIR/bootstrap/cache"

echo "Done. Настройте Nginx, Supervisor, cron и .env вручную — см. docs/DEPLOY/12_vps_production.md"
