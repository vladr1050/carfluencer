# --- Local dev (recommended, especially Safari) ---
# Leave VITE_API_URL **unset** so the browser calls `/api/...` on the Vite dev server;
# Vite proxies to Laravel (vite.config.ts → 127.0.0.1:8000).
# If Laravel is elsewhere (dev proxy target only):
# LARAVEL_DEV_URL=http://127.0.0.1:8001

# --- Direct API URL (optional; can break Safari if host differs from the page, e.g. localhost vs 127.0.0.1) ---
# VITE_API_URL=http://127.0.0.1:8000

# Production build: set the real API origin.
# VITE_API_URL=https://api.yourdomain.com

# Advertiser heatmap basemap matches admin: set MAPTILER_API_KEY in Laravel .env.
# The SPA loads tiles via GET /api/advertiser/map-basemap (no Vite env key needed).
