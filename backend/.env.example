APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Comma-separated origins for the React SPA (CORS). Leave unset to allow all (*).
# Include :5174 when using the Figma bundle in design/Files.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
FRONTEND_URL=http://localhost:5173

# Optional: MapTiler "Positron" tiles for admin heatmap (Filament). If unset, CARTO Positron (light_all) is used.
# MAPTILER_API_KEY=

# Optional: remote JSON for advertiser dashboard (see config/telemetry.php)
# TELEMETRY_METRICS_URL=
# TELEMETRY_METRICS_TOKEN=

# Heatmap: database (PostgreSQL device_locations) or mock demo points
# TELEMETRY_HEATMAP_DRIVER=database
# Emphasize highest-density buckets: intensity = (w/maxW)^gamma (1=linear, default 1.55)
# TELEMETRY_HEATMAP_INTENSITY_GAMMA=1.55

# ClickHouse → PostgreSQL collector (device_locations). IMEI must match ClickHouse device_id.
# TELEMETRY_CLICKHOUSE_ENABLED=false
# Test: php artisan telemetry:test-clickhouse  (optional --url=…)
# TELEMETRY_CLICKHOUSE_URL=http://178.63.17.153:8123
# TELEMETRY_CLICKHOUSE_DATABASE=default
# TELEMETRY_CLICKHOUSE_USER=
# TELEMETRY_CLICKHOUSE_PASSWORD=
# Production CH table `location` (imei, unix timestamp, gpsSpeed):
# TELEMETRY_CLICKHOUSE_LOCATIONS_TABLE=location
# TELEMETRY_CH_SCHEMA_PRESET=location
# TELEMETRY_CH_TIMESTAMP_COLUMN=timestamp
# TELEMETRY_CH_TIMESTAMP_TYPE=unix_seconds
# TELEMETRY_CH_DEVICE_ID_COLUMN=imei
# TELEMETRY_CH_SPEED_COLUMN=gpsSpeed
# Legacy-style CH table with device_id + DateTime timestamp:
# TELEMETRY_CH_SCHEMA_PRESET=legacy
# TELEMETRY_CH_TIMESTAMP_TYPE=datetime_string
# Optional extra SQL appended after the built-in SELECT (advanced)
# TELEMETRY_CLICKHOUSE_SELECT_SUFFIX=
#
# Throttle external ClickHouse (large fleets): rows per IMEI per request, pause between IMEIs,
# max IMEIs per scheduler minute tick (0 = unlimited), global CLI sync-incremental batch, HTTP timeout.
# TELEMETRY_CH_INCREMENTAL_ROWS_PER_IMEI=15000
# TELEMETRY_CH_PAUSE_MS_BETWEEN_IMEI=300
# TELEMETRY_CH_MAX_IMEIS_PER_TICK=35
# TELEMETRY_CH_GLOBAL_INCREMENTAL_ROWS=25000
# TELEMETRY_CH_HISTORICAL_ROWS_PER_CHUNK=80000
# Max pages per historical window (safety cap; each page pulls up to ROWS_PER_CHUNK rows)
# TELEMETRY_CH_HISTORICAL_MAX_PAGES=50000
# TELEMETRY_CH_HISTORICAL_IMEI_CHUNK=40
# TELEMETRY_CH_PAUSE_MS_HISTORICAL_CHUNK=500
# TELEMETRY_CH_HTTP_TIMEOUT=120

# Analytics tuning (stop sessions + daily impressions)
# TELEMETRY_PARKING_SPEED_MAX=3
# TELEMETRY_MIN_SESSION_SECONDS=60
# TELEMETRY_IMPRESSION_MULTIPLIER=10

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Human-readable rotation (default). Add daily_json for JSON Lines: LOG_STACK=daily,daily_json
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=30
# Slack alerts (optional): set URL; only LOG_SLACK_LEVEL and above are sent
# LOG_SLACK_WEBHOOK_URL=
# LOG_SLACK_LEVEL=critical
# LOG_SLACK_USERNAME="${APP_NAME}"

DB_CONNECTION=sqlite
# Для «один в один» клона БД на прод (PostgreSQL) удобнее локально тоже использовать pgsql — см. docs/OPERATIONS/03_full_database_sync.md
# Снимок текущей БД: php artisan db:export-snapshot → storage/app/db-snapshots/
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Use "public" so vehicle images and proofs are web-accessible via storage:link
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Telemetry / ClickHouse (см. backend/.env.production.example и deploy/telemetry.env.fragment) ---
# На проде после git pull: deploy/post-pull.sh вызывает php artisan telemetry:ensure-env (добавляет только отсутствующие ключи).
TELEMETRY_HEATMAP_DRIVER=database
# TELEMETRY_HEATMAP_MAX_DATE_RANGE_DAYS=120
TELEMETRY_CLICKHOUSE_ENABLED=false
TELEMETRY_CLICKHOUSE_URL=http://178.63.17.153:8123
TELEMETRY_CLICKHOUSE_DATABASE=default
TELEMETRY_CLICKHOUSE_USER=
TELEMETRY_CLICKHOUSE_PASSWORD=
TELEMETRY_CLICKHOUSE_LOCATIONS_TABLE=location
TELEMETRY_CH_SCHEMA_PRESET=location
TELEMETRY_CH_TIMESTAMP_COLUMN=timestamp
TELEMETRY_CH_TIMESTAMP_TYPE=unix_seconds
TELEMETRY_CH_DEVICE_ID_COLUMN=imei
TELEMETRY_CH_SPEED_COLUMN=gpsSpeed
# TELEMETRY_CLICKHOUSE_SELECT_SUFFIX=
TELEMETRY_CH_INCREMENTAL_ROWS_PER_IMEI=15000
TELEMETRY_CH_PAUSE_MS_BETWEEN_IMEI=300
TELEMETRY_CH_MAX_IMEIS_PER_TICK=35
TELEMETRY_CH_GLOBAL_INCREMENTAL_ROWS=25000
TELEMETRY_CH_HISTORICAL_ROWS_PER_CHUNK=80000
TELEMETRY_CH_HISTORICAL_IMEI_CHUNK=40
TELEMETRY_CH_PAUSE_MS_HISTORICAL_CHUNK=500
TELEMETRY_CH_HTTP_TIMEOUT=120
