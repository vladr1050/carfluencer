# Production template — copy to .env on the server and replace CHANGE_ME / YOUR_* values.
#   cp .env.production.example .env
#   nano .env
#   composer install --no-dev && php artisan key:generate && php artisan migrate --force

APP_NAME=Carfluencer
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Public URL users open in browser (no trailing slash). After certbot: https://
APP_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# После включения HTTPS раскомментируй:
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

# SPA / API CORS — list real origins or leave unset for * (see config/cors.php)
# CORS_ALLOWED_ORIGINS=https://your-frontend.example,http://YOUR_SERVER_IP:5174
FRONTEND_URL=http://YOUR_SERVER_IP_OR_DOMAIN

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- PostgreSQL (create user/db first; see docs/DEPLOY/12_vps_production.md) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=evo
DB_USERNAME=evo
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Telemetry (optional) ---
# TELEMETRY_METRICS_URL=
# TELEMETRY_METRICS_TOKEN=
TELEMETRY_HEATMAP_DRIVER=database

TELEMETRY_CLICKHOUSE_ENABLED=false
# TELEMETRY_CLICKHOUSE_URL=http://clickhouse-host:8123
# TELEMETRY_CLICKHOUSE_DATABASE=default
# TELEMETRY_CLICKHOUSE_USER=
# TELEMETRY_CLICKHOUSE_PASSWORD=
# TELEMETRY_CLICKHOUSE_LOCATIONS_TABLE=location
# TELEMETRY_CH_SCHEMA_PRESET=location
# TELEMETRY_CH_TIMESTAMP_TYPE=unix_seconds
# TELEMETRY_CH_DEVICE_ID_COLUMN=imei
# TELEMETRY_CH_SPEED_COLUMN=gpsSpeed

# --- Первый админ (после migrate на сервере) ---
# cd backend && sudo -u www-data php artisan make:filament-user
