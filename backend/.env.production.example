# Production template — copy to .env on the server and replace CHANGE_ME / YOUR_* values.
#   cp .env.production.example .env
#   nano .env
#   composer install --no-dev && php artisan key:generate && php artisan migrate --force

APP_NAME=Carfluencer
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Public URL users open in browser (no trailing slash).
APP_URL=https://www.carplace.lv

# После certbot / HTTPS:
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# SPA на том же хосте — перечислите www и apex (если открываете оба).
CORS_ALLOWED_ORIGINS=https://www.carplace.lv,https://carplace.lv
FRONTEND_URL=https://www.carplace.lv

# Sanctum SPA / cookie sessions: домены без схемы, через запятую.
SANCTUM_STATEFUL_DOMAINS=www.carplace.lv,carplace.lv

# Общая cookie-зона для www и apex.
SESSION_DOMAIN=.carplace.lv

# Optional: MapTiler Positron tiles for admin heatmap (else CARTO Positron / light_all).
# MAPTILER_API_KEY=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
# Optional second file: JSON per line for Loki / ELK / CloudWatch
# LOG_STACK=daily,daily_json
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30
# LOG_SLACK_WEBHOOK_URL=
# LOG_SLACK_LEVEL=critical

# --- PostgreSQL (create user/db first; see docs/DEPLOY/12_vps_production.md) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=evo
DB_USERNAME=evo
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Telemetry (ClickHouse → PostgreSQL / heatmap) ---
# TELEMETRY_METRICS_URL=
# TELEMETRY_METRICS_TOKEN=
TELEMETRY_HEATMAP_DRIVER=database
# Подсветка пиков на heatmap: intensity=(w/max)^γ; 1=линейно, выше — ярче только самые густые ячейки (дефолт в config 1.55)
# TELEMETRY_HEATMAP_INTENSITY_GAMMA=1.55
# Max gap (seconds) between GPS points when estimating parking hours on heatmap (ignore longer gaps).
# TELEMETRY_HEATMAP_MAX_PARKING_SEGMENT_SECONDS=7200
# Опционально: макс. длина периода heatmap в календарных днях (advertiser + admin). Пусто = без лимита.
# TELEMETRY_HEATMAP_MAX_DATE_RANGE_DAYS=120

# Внешний ClickHouse; если телеметрия не нужна на стенде — поставьте false.
TELEMETRY_CLICKHOUSE_ENABLED=true
TELEMETRY_CLICKHOUSE_URL=http://178.63.17.153:8123
TELEMETRY_CLICKHOUSE_DATABASE=default
TELEMETRY_CLICKHOUSE_USER=
TELEMETRY_CLICKHOUSE_PASSWORD=
TELEMETRY_CLICKHOUSE_LOCATIONS_TABLE=location
TELEMETRY_CH_SCHEMA_PRESET=location
TELEMETRY_CH_TIMESTAMP_COLUMN=timestamp
TELEMETRY_CH_TIMESTAMP_TYPE=unix_seconds
TELEMETRY_CH_DEVICE_ID_COLUMN=imei
TELEMETRY_CH_SPEED_COLUMN=gpsSpeed
# TELEMETRY_CLICKHOUSE_SELECT_SUFFIX=

TELEMETRY_CH_INCREMENTAL_ROWS_PER_IMEI=15000
TELEMETRY_CH_PAUSE_MS_BETWEEN_IMEI=300
TELEMETRY_CH_MAX_IMEIS_PER_TICK=35
TELEMETRY_CH_GLOBAL_INCREMENTAL_ROWS=25000
TELEMETRY_CH_HISTORICAL_ROWS_PER_CHUNK=80000
TELEMETRY_CH_HISTORICAL_IMEI_CHUNK=40
TELEMETRY_CH_PAUSE_MS_HISTORICAL_CHUNK=500
TELEMETRY_CH_HTTP_TIMEOUT=120

# --- Первый админ (после migrate на сервере) ---
# cd backend && sudo -u www-data php artisan make:filament-user
